SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Direct Postgres connection (Settings > Database > Connection string > Transaction mode)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

PORT=3000

# "development" | "production". Production gates CORS and verbose errors.
NODE_ENV=development

# "debug" | "info" | "warn" | "error" | "fatal" — defaults to info in prod, debug otherwise.
LOG_LEVEL=debug

# Comma-separated list of allowed CORS origins, only enforced when NODE_ENV=production.
# CORS_ORIGINS=https://app.elos.app,https://elos.app
