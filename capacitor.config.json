{
  "appId": "com.elos.app",
  "appName": "ELOS",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#000000",
    "scrollEnabled": false
  },
  "plugins": {
    "StatusBar": {
      "style": "Default",
      "backgroundColor": "#00000000",
      "overlaysWebView": true
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true,
      "style": "Dark"
    }
  }
}
